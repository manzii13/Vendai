    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
