PORT=5000

# Local development (API + Postgres on your machine):
DATABASE_URL="postgresql://postgres:admin123@localhost:5432/vendai"

# Docker Compose sets DATABASE_URL automatically — do not use `localhost` inside containers.

JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
ANTHROPIC_API_KEY=
NODE_ENV=development
